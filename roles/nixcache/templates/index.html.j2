<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>nixcache.ru — Прокси и бинарный кеш Nix для России</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Courier New', monospace;
      background: #0d1117;
      color: #e6edf3;
      min-height: 100vh;
    }

    header {
      background: #161b22;
      border-bottom: 1px solid #30363d;
      padding: 1.2rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    header .logo {
      font-size: 1.5rem;
      font-weight: bold;
      color: #5294e2;
      letter-spacing: -1px;
    }

    header .logo span { color: #7ee787; }

    nav a {
      color: #8b949e;
      text-decoration: none;
      margin-left: 1.5rem;
      font-size: 0.9rem;
    }

    nav a:hover { color: #e6edf3; }

    .hero {
      padding: 2.5rem 2rem;
      border-bottom: 1px solid #21262d;
    }

    .hero-main {
      display: flex;
      flex-direction: row;
      align-items: stretch;
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
      text-align: left;
    }

    .hero-text {
      flex: 1;
      min-width: 0;
    }

    .hero-text h1 {
      font-size: 2rem;
      color: #7ee787;
      margin-bottom: 0.8rem;
      line-height: 1.2;
    }

    .hero-text p {
      font-size: 1rem;
      color: #8b949e;
      line-height: 1.7;
      margin-bottom: 1.2rem;
    }

    .hero-main .setup-block {
      flex: 1.4;
      min-width: 0;
      margin-top: 0;
      position: relative;
    }

    .copy-btn {
      position: absolute;
      top: 0.8rem;
      right: 0.8rem;
      background: #21262d;
      border: 1px solid #30363d;
      color: #8b949e;
      border-radius: 4px;
      padding: 0.25rem 0.6rem;
      font-size: 0.75rem;
      cursor: pointer;
      font-family: inherit;
      transition: color 0.15s, border-color 0.15s;
    }

    .copy-btn:hover { color: #e6edf3; border-color: #8b949e; }
    .copy-btn.copied { color: #7ee787; border-color: #7ee787; }

    @media (max-width: 700px) {
      .hero-main { flex-direction: column; }
      .hero-text h1 { font-size: 1.5rem; }
    }

    .badge {
      display: inline-block;
      background: #1f6feb22;
      border: 1px solid #1f6feb;
      color: #58a6ff;
      padding: 0.3rem 0.9rem;
      border-radius: 2rem;
      font-size: 0.85rem;
      font-weight: normal;
      white-space: nowrap;
    }

    .cta-btn {
      display: inline-block;
      background: #238636;
      color: #fff;
      padding: 0.7rem 1.8rem;
      border-radius: 6px;
      text-decoration: none;
      font-size: 1rem;
      font-weight: bold;
      transition: background 0.2s;
    }

    .cta-btn.secondary {
      font-weight: normal;
      padding: 0.6rem 1.4rem;
      font-size: 0.9rem;
    }

    .cta-btn:hover { background: #2ea043; }
    .cta-btn.secondary:hover { background: #1a7fd4; }

    .cta-buttons {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 0.2rem;
    }

    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    .section h2 {
      font-size: 1.4rem;
      color: #e6edf3;
      margin-bottom: 1.5rem;
      border-left: 3px solid #7ee787;
      padding-left: 0.8rem;
    }

    /* --- Posters --- */
    .posters {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.2rem;
    }

    .poster {
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 8px;
      padding: 2rem 1.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .poster::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }

    .poster.red::before   { background: #da3633; }
    .poster.blue::before  { background: #1f6feb; }
    .poster.green::before { background: #238636; }

    .poster-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    .poster h3 {
      font-size: 1.1rem;
      color: #e6edf3;
      margin-bottom: 0.6rem;
      line-height: 1.3;
    }

    .poster p {
      font-size: 0.85rem;
      color: #8b949e;
      line-height: 1.6;
    }

    /* --- Info cards --- */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .card {
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 8px;
      padding: 1.4rem;
    }

    .card .label {
      font-size: 0.75rem;
      color: #7ee787;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 0.4rem;
    }

    .card p {
      color: #8b949e;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* --- Setup block --- */
    .setup-block {
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 8px;
      padding: 1.5rem;
      margin-top: 1rem;
    }

    .setup-block code {
      display: block;
      background: #0d1117;
      border: 1px solid #30363d;
      border-radius: 6px;
      padding: 1rem 1.2rem;
      color: #7ee787;
      font-size: 0.88rem;
      white-space: pre;
      overflow-x: auto;
      margin-top: 0.8rem;
      min-height: 5.5rem;
    }

    .setup-block p {
      color: #8b949e;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    /* --- Roadmap --- */
    .roadmap {
      list-style: none;
      margin-top: 1rem;
    }

    .roadmap li {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.2rem;
      background: #161b22;
      border: 1px solid #30363d;
      border-radius: 8px;
      margin-bottom: 0.75rem;
    }

    .roadmap .step {
      font-size: 0.75rem;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 1px;
      white-space: nowrap;
      padding-top: 0.1rem;
    }

    .roadmap .step.done  { color: #7ee787; }
    .roadmap .step.plan  { color: #8b949e; }

    .roadmap .desc strong { color: #e6edf3; display: block; margin-bottom: 0.2rem; }
    .roadmap .desc span   { color: #8b949e; font-size: 0.88rem; line-height: 1.5; }

    /* --- Footer --- */
    footer {
      border-top: 1px solid #21262d;
      text-align: center;
      padding: 1.5rem;
      color: #484f58;
      font-size: 0.85rem;
    }

    footer a { color: #58a6ff; text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.7rem; }
      header { flex-wrap: wrap; }
    }
  </style>
</head>
