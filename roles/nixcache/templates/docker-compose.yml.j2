services:
  traefik:
    image: {{ traefik_image }}
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ traefik_config_dir }}/traefik.yml:/etc/traefik/traefik.yml:ro
      - {{ traefik_config_dir }}/dynamic.yml:/etc/traefik/dynamic.yml:ro
      - /var/log/traefik:/var/log/traefik
{% if domain_name != "" %}
      - {{ traefik_config_dir }}/acme.json:/etc/traefik/acme.json
{% endif %}

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - {{ traefik_config_dir }}/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - {{ traefik_config_dir }}/www:/usr/share/nginx/html:ro
      - {{ nginx_cache_dir }}:{{ nginx_cache_dir }}
    ports:
      - "127.0.0.1:8081:8080"
